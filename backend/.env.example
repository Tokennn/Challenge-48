APP_NAME=challenge-48h-backend
APP_ENV=dev
APP_PORT=8787

DB_HOST=postgres-primary
DB_PORT=5432
DB_NAME=air_map
DB_USER=air_map_app
DB_PASSWORD_FILE=/run/secrets/app_db_password

DATA_API_BASE_URL=http://data-api:8000
DATA_API_HISTORY_DAYS=10
DATA_API_TIMEOUT_SECONDS=60
DATA_API_REFRESH_ON_SYNC=true

ENABLE_SYNC_WORKER=true
SYNC_ON_STARTUP=true
SYNC_INTERVAL_SECONDS=300

CORS_ORIGINS=http://localhost:5173
