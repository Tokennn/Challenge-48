# Docker Compose project
COMPOSE_PROJECT_NAME=air-map

# Frontend container
FRONTEND_CONTAINER_NAME=air-map-frontend
FRONTEND_PORT=5173
VITE_APP_NAME=AirMap

# PostgreSQL container
POSTGRES_CONTAINER_NAME=air-map-postgres
POSTGRES_DB=air_map
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_PORT=5432

# Future backend / data API connection string (container-to-container)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/air_map
